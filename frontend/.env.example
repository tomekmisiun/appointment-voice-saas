# Server-only — never prefixed NEXT_PUBLIC_. The browser never calls the
# FastAPI backend directly; all backend calls happen inside Next.js server
# code (Server Components, Route Handlers, Server Actions), which is why
# this URL never needs to be exposed to client JS or allowed via CORS.
BACKEND_API_URL=http://localhost:8000

# AES-256-GCM key for the encrypted session cookie. Must be 32 random bytes,
# base64-encoded. Generate one with:
#   openssl rand -base64 32
# There is no development fallback — a missing/malformed/short secret fails
# fast and loudly in every environment, including local dev.
SESSION_SECRET=replace-with-output-of-openssl-rand--base64-32

# This app's own public origin, used only to validate the Origin/Referer
# header on state-changing Route Handlers (login, logout). Not a CORS
# setting — it never reaches the backend.
APP_ORIGIN=http://localhost:3000
# Optional comma-separated trusted origins for the same frontend deployment,
# for example a Railway-generated domain plus a custom domain.
APP_ORIGIN_ALIASES=

# Enable only when a trusted reverse proxy replaces X-Forwarded-For and
# X-Real-IP before traffic reaches Next.js. This lets the BFF preserve the
# original client address for backend login/signup rate limits.
BFF_TRUST_FORWARDED_HEADERS=false

# Optional. Which backend tenant this deployment's login should
# authenticate against (sent as X-Tenant-Slug on the login call only).
# Leave unset to use the backend's own default tenant ("default"), which
# matches the seeded demo data. Only matters once this dashboard serves a
# tenant other than "default" — see lib/api/config.ts for why this is
# deliberately never sent on authenticated requests.
# TENANT_SLUG=acme
